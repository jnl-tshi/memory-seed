{
  "version": 1,
  "hooks": {
    "afterAgentResponse": [
      {
        "command": "python3 .memory-seed/hooks/session-log-check.py --cursor"
      }
    ],
    "sessionStart": [
      {
        "command": "python3 .memory-seed/hooks/memory-retrieval-check.py --cursor"
      },
      {
        "command": "python3 .memory-seed/hooks/session-start-context.py --cursor"
      }
    ]
  }
}
