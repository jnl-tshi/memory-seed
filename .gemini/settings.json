{
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 .memory-seed/hooks/session-log-check.py --gemini"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 .memory-seed/hooks/memory-retrieval-check.py --gemini"
          }
        ]
      }
    ]
  },
  "mcpServers": {
    "memory-seed": {
      "command": "uvx",
      "args": [
        "--from",
        "memory-seed",
        "memory-seed-mcp",
        "--stdio"
      ]
    }
  }
}
