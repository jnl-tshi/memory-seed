{
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 .memory-seed/hooks/session-log-check.py --codex"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 .memory-seed/hooks/memory-retrieval-check.py --codex"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 .memory-seed/hooks/session-start-context.py --codex"
          }
        ]
      }
    ]
  }
}
